{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["@types/bun"]
  },
  "include": ["examples/**/*.ts", "examples/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
